# --- Telegram ---
# Get a token from @BotFather on Telegram
BOT_TOKEN=123456:ABCDEF_your_bot_token_here

# --- Database ---
# Development (default): SQLite via aiosqlite
DATABASE_URL=sqlite+aiosqlite:///./expense_bot.db
# Production example (PostgreSQL via asyncpg):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/expense_bot

# --- Application ---
LOG_LEVEL=INFO
ENVIRONMENT=development
DEFAULT_CURRENCY=USD
DEFAULT_TIMEZONE=UTC

# --- Reminders ---
# Enable/disable the daily reminder scheduler
REMINDERS_ENABLED=true
